# Copy this file to .env and update values
USE_MOCK_DATA=true

# Optional for later: real DB mode
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/your_db

# Optional for AI mode (fallback responses are used if missing)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
APP_NAME=AutoReport
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
